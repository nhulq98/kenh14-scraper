# ============================================================
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values

# ============================================================
# Server Config
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# Gemini API Keys (Required for AI summarization)
# Get from: https://ai.google.dev/
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY1=your_gemini_api_key_2_optional
GEMINI_API_KEY2=your_gemini_api_key_3_optional
GEMINI_API_KEY3=your_gemini_api_key_4_optional

# ============================================================
# Facebook Graph API (Optional - for real Facebook stats)
# Setup:
# 1. Go to https://developers.facebook.com/
# 2. Create an app or use existing
# 3. Get Page Access Token from: https://developers.facebook.com/tools/explorer/
# 4. Or use Graph API Explorer: https://developers.facebook.com/tools/explorer/
# 
# Instructions:
# - Create a test app or use production app
# - Get user access token with pages_read_engagement permission
# - Test with: GET /me/accounts
# - For page posts: GET /{page-id}/posts?fields=engagement
# ============================================================
FB_ACCESS_TOKEN=

# ============================================================
# Google Trends API (Optional)
# Setup:
# - Install google-trends-api: npm install google-trends-api
# - No authentication needed, just uses Google Trends data
# 
# Alternative: Use Google Custom Search API
# - Cost: $5 per 1000 queries
# - Setup: https://developers.google.com/custom-search
# - Get API Key: https://console.developers.google.com/
# ============================================================
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ============================================================
# TikTok API (Optional - unofficial)
# Setup:
# - Install: npm install tiktok-api-unofficial
# - Or use: npm install tiktok-scraper
# 
# Note: TikTok doesn't have official public API
# - Using unofficial scraping API (may break if TikTok changes)
# - Rate limits: ~50 requests per minute
# 
# Alternative: Use browser automation
# - Install: npm install puppeteer
# - More reliable but slower (10s+ per request)
# ============================================================
TIKTOK_SESSION_ID=
TIKTOK_CSRF_TOKEN=

# ============================================================
# Logging & Debug
# ============================================================
DEBUG=false
LOG_LEVEL=info
