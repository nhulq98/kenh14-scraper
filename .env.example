# ==================== GEMINI AI CONFIGURATION ====================
# Google Gemini API Keys - Để sử dụng tính năng tóm tắt AI
# Lấy API keys từ: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY1=your_gemini_api_key_1_here
GEMINI_API_KEY2=your_gemini_api_key_2_here
GEMINI_API_KEY3=your_gemini_api_key_3_here

# ==================== VIETTEL TEXT-TO-SPEECH (TTS) CONFIGURATION ====================
# Token API từ Viettel AI - Để sử dụng tính năng chuyển văn bản thành âm thanh
# Đăng ký tài khoản: https://viettelai.vn/
# Lấy token từ dashboard API

VIETTEL_TTS_TOKEN=your_viettel_tts_token_here

# ==================== NOTES ====================
# 1. Không commit file .env vào git repository - chỉ dùng .env.example
# 2. Giữ bí mật các API keys - không share công khai
# 3. Thay thế "your_*_here" bằng giá trị thực tế
